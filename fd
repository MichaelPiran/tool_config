#!/usr/bin/env bash

set -euo pipefail

max_depth="${1:-3}"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    SOURCE="git ls-files --cached --others --exclude-standard"
else
    SOURCE="rg --files"
fi

selected=$(
    eval "$SOURCE" \
    | xargs -n1 dirname \
    | sort -u \
    | awk -F/ -v max="$max_depth" 'NF<=max' \
    | fzf
)

[ -n "$selected" ] && printf '%s\n' "$selected"
